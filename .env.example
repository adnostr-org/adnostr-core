# AdNostr-Core Environment Configuration
# Copy this file to .env and fill in your actual values

# FastAPI Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Mastodon API Configuration for admin.adnostr.org
MASTODON_BASE_URL=https://admin.adnostr.org
MASTODON_ACCESS_TOKEN=your_mastodon_access_token_here
MASTODON_CLIENT_ID=your_client_id_here
MASTODON_CLIENT_SECRET=your_client_secret_here

# Toot CLI Configuration (for multi-account support)
TOOT_CONFIG_DIR=/path/to/toot/config
TOOT_ACTIVE_ACCOUNT=adnostr-admin

# AI Image Generation API (placeholder for future integration)
AI_API_KEY=your_ai_api_key_here
AI_API_ENDPOINT=https://api.example.com/generate-image

# Revenue Calculation Parameters
REVENUE_CONSTANT_C=1.5
REVENUE_EXPONENT_K=0.8

# TickleBell Database Configuration
TICKLEBELL_AVATAR_DB=/path/to/ticklebell/avatar.db

# AdNostr Local Database
ADNOSTR_DATA_DB=adnostr_data.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json